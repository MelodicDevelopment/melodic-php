# Exclude non-essential files from Composer installs (composer install --prefer-dist)
# Users get src/, bin/, .claude/ (agents/skills), composer.json, LICENSE, and README.md
/tests               export-ignore
/web                 export-ignore
/docs                export-ignore
/phpstan.neon        export-ignore
/phpunit.xml         export-ignore
/CLAUDE.md           export-ignore
/PUBLISHING.md       export-ignore
/.gitattributes      export-ignore
/.gitignore          export-ignore
/.github             export-ignore
/.claude/settings.local.json  export-ignore
/.phpunit.cache      export-ignore
