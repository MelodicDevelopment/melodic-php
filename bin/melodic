#!/usr/bin/env php
<?php

declare(strict_types=1);

// Autoload: framework development (repo checkout) or installed as a dependency
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',       // framework repo
    __DIR__ . '/../../../autoload.php',         // installed via composer (vendor/bin/)
];

$loaded = false;
foreach ($autoloadPaths as $autoload) {
    if (file_exists($autoload)) {
        require_once $autoload;
        $loaded = true;
        break;
    }
}

if (!$loaded) {
    fwrite(STDERR, "Autoloader not found. Run 'composer install' first." . PHP_EOL);
    exit(1);
}

use Melodic\Console\Console;
use Melodic\Console\ClaudeInstallCommand;
use Melodic\Console\Make\MakeConfigCommand;
use Melodic\Console\Make\MakeEntityCommand;
use Melodic\Console\Make\MakeProjectCommand;

$console = new Console();
$console->setName('Melodic');

$console->register(new MakeProjectCommand());
$console->register(new MakeEntityCommand());
$console->register(new MakeConfigCommand());
$console->register(new ClaudeInstallCommand());

exit($console->run($argv));
