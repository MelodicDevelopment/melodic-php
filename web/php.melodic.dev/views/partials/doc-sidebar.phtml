<?php
$sidebarType = $viewBag->sidebarType ?? 'docs';
$currentPage = $viewBag->currentPage ?? null;
?>
<aside class="sidebar">
    <?php if ($sidebarType === 'tutorials'): ?>
        <div class="sidebar-section">
            <div class="sidebar-heading">Tutorials</div>
            <a href="/tutorials"<?= $currentPage === null ? ' class="active"' : '' ?>>Overview</a>
            <?php foreach ($viewBag->tutorials as $slug => $label): ?>
                <a href="/tutorials/<?= $slug ?>"<?= ($currentPage === $slug) ? ' class="active"' : '' ?>><?= htmlspecialchars($label) ?></a>
            <?php endforeach; ?>
        </div>
    <?php else: ?>
        <div class="sidebar-section">
            <div class="sidebar-heading" style="margin-bottom: 0.6rem;">
                <a href="/docs" style="color: var(--text-muted); text-decoration: none; text-transform: uppercase; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;"<?= $currentPage === null ? ' class="active"' : '' ?>>Overview</a>
            </div>
        </div>
        <?php foreach ($viewBag->sections as $sectionName => $sectionPages): ?>
            <div class="sidebar-section">
                <div class="sidebar-heading"><?= htmlspecialchars($sectionName) ?></div>
                <?php foreach ($sectionPages as $slug => $label): ?>
                    <a href="/docs/<?= $slug ?>"<?= ($currentPage === $slug) ? ' class="active"' : '' ?>><?= htmlspecialchars($label) ?></a>
                <?php endforeach; ?>
            </div>
        <?php endforeach; ?>
    <?php endif; ?>
</aside>
